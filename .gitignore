# Testing / temp
/coverage
/.nyc_output
/test-results/
playwright-report/
blob-report/
test-results/

# Deployment / Render specific (usually not needed, but good to have)
.render/
render.yaml   # if you commit Render config (most people don't)

# PDF / upload / temp user files (if you have local testing folders)
uploads/
temp/
tmp/
*.pdf   # ← only if you accidentally save test resumes locally; remove if you want to commit sample PDFs

# Framer Motion / animation build artifacts (rare, but sometimes appears)
.motion/

# Optional: if using TypeScript
*.tsbuildinfo
next-env.d.ts

