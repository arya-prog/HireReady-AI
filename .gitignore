# Build / dist folders (frontend + backend)
dist/
build/
out/
.next/
.vercel/
.output/

# Environment variables & secrets (critical!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.env.*
config/.env*
credentials.json
serviceAccountKey.json
razorpay-keys.*
*.pem
*.key
*.cert

# Editor / IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# OS / temporary files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.AppleDouble
.Trashes

# Logs & caches
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
*.pid
*.seed
*.pid.lock
coverage/
